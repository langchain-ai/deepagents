# Model provider
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Vercel Sandbox auth (the `vercel` SDK reads these from the environment)
VERCEL_TOKEN=your_vercel_token_here
VERCEL_TEAM_ID=your_team_id_here
VERCEL_PROJECT_ID=your_project_id_here

# Optional: boot from a pre-baked snapshot instead of pip-installing per run.
# Produced by `python bake_snapshot.py`.
# VERCEL_SANDBOX_SNAPSHOT_ID=snap_xxx

# Optional: demonstrate credential brokering. When both are set, the sandbox can
# call APP_API_HOST authenticated while never holding APP_API_TOKEN — the
# firewall injects the Authorization header on egress.
# APP_API_HOST=api.yourapp.com
# APP_API_TOKEN=your_app_api_token_here
