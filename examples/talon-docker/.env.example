# Runtime
AGENT_ASSISTANT_ID=talon-docker-local
AGENT_MODEL=

# Provider credentials. Keep real values only in your local `.env`.
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# WhatsApp is enabled by default for this example.
# Scan the QR code with your phone to bridge WhatsApp to Talon. Set allowlists and mention patterns to control exposure.
DEEPAGENTS_TALON_WHATSAPP_ENABLED=true
DEEPAGENTS_TALON_WHATSAPP_START_BRIDGE=true
DEEPAGENTS_TALON_WHATSAPP_EXPOSURE=self
DEEPAGENTS_TALON_WHATSAPP_ALLOWLIST_CHATS=
DEEPAGENTS_TALON_WHATSAPP_MENTION_PATTERNS=

# Telegram is disabled by default. Set the bot token and allowlists before enabling.
# Ask @botfather for a bot token to enable Telegram integration.
# Ask @userinfobbot for user and chat IDs to populate the allowlists.
DEEPAGENTS_TALON_TELEGRAM_ENABLED=false
DEEPAGENTS_TALON_TELEGRAM_BOT_TOKEN=
DEEPAGENTS_TALON_TELEGRAM_EXPOSURE=allowlist
DEEPAGENTS_TALON_TELEGRAM_ALLOWLIST_USERS=
DEEPAGENTS_TALON_TELEGRAM_ALLOWLIST_CHATS=
DEEPAGENTS_TALON_TELEGRAM_MENTION_PATTERNS=

# Voice transcription applies to inbound channel media.
DEEPAGENTS_TALON_VOICE_TRANSCRIPTION_ENABLED=true
DEEPAGENTS_TALON_VOICE_TRANSCRIPTION_DEVICE=cpu

# Optional tracing.
LANGSMITH_TRACING=false
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=deepagents-talon
