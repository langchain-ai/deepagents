# Model configuration
AGENT_MODEL=claude-sonnet-4-6
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
OPENAI_BASE_URL=

# LangGraph recursion limit (max steps per agent run). Defaults to 150.
AGENT_RECURSION_LIMIT=150

# WhatsApp configuration
WHATSAPP_BRIDGE_PORT=3000
WHATSAPP_SESSION_PATH=./session

# Safe default: only respond to messages you send to yourself. Useful
# for trying the example without risking replies to strangers or groups.
# Set to `false` to accept messages from other contacts.
WHATSAPP_SELF_ONLY=true

WHATSAPP_REQUIRE_MENTION=false
WHATSAPP_MENTION_PATTERNS=
WHATSAPP_FREE_RESPONSE_CHATS=

# Cron jobs file. Defaults to
# ~/.deepagents/<AGENT_ASSISTANT_ID>/cron/jobs.json (lives in the CLI tree
# so it's host-editable and persists across container rebuilds).
WHATSAPP_CRON_PATH=

# Agent folder under ~/.deepagents/ — controls where skills/memory/cron
# are auto-loaded from (matches the CLI layout: `deepagents <agent-name>`).
AGENT_ASSISTANT_ID=whatsapp

# Skills — `;`- or `:`-separated list of extra skill source dirs. Appended
# AFTER the default ~/.deepagents/<AGENT_ASSISTANT_ID>/skills/ (auto-created).
SKILLS_DIRS=

# Memory — `;`- or `:`-separated list of AGENTS.md files loaded into the
# system prompt. Defaults to ~/.deepagents/<AGENT_ASSISTANT_ID>/AGENTS.md.
AGENT_MEMORY_PATHS=

# MCP tools — path to a Claude-Desktop-style mcpServers JSON. When unset,
# falls back to ~/.deepagents/.mcp.json (the CLI's global location).
MCP_CONFIG=

# Observability (optional)
LANGSMITH_API_KEY=
LANGSMITH_TRACING=false

# Speech / voice messages
# Set to `true` to enable local transcription of WhatsApp voice messages using
# NVIDIA Parakeet TDT 0.6B v3 via NeMo (CPU inference by default).
# Requires:  pip install 'nemo_toolkit[asr]'  and  ffmpeg  on PATH.
# Set SPEECH_DEVICE=cuda to use a GPU instead of CPU.
SPEECH_ENABLED=false
SPEECH_DEVICE=cpu
