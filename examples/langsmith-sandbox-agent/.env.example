# LangSmith auth for sandboxes. Use a configured SDK profile...
LANGSMITH_PROFILE=prod
# ...or an explicit API key (and optionally a custom endpoint):
# LANGSMITH_API_KEY=lsv2_...
# LANGSMITH_ENDPOINT=https://api.smith.langchain.com

# Real model key. The sandbox auth proxy injects this on egress to Anthropic,
# so the box itself only ever sees a dummy value.
ANTHROPIC_API_KEY=sk-ant-...
