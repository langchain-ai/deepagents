{
  "platform": "douyin",
  "page": "login",
  "description": "抖音登录页面元素",
  "elements": {
    "username_input": {
      "selectors": [
        {"type": "css", "value": "input[name='username']"},
        {"type": "xpath", "value": "//input[@name='username']"},
        {"type": "css", "value": "input[placeholder*='手机号']"},
        {"type": "css", "value": "input[placeholder*='用户名']"}
      ],
      "description": "用户名输入框",
      "version": 1
    },
    "password_input": {
      "selectors": [
        {"type": "css", "value": "input[name='password']"},
        {"type": "xpath", "value": "//input[@name='password']"},
        {"type": "css", "value": "input[placeholder*='密码']"}
      ],
      "description": "密码输入框",
      "version": 1
    },
    "login_button": {
      "selectors": [
        {"type": "css", "value": "button[type='submit']"},
        {"type": "xpath", "value": "//button[@type='submit']"},
        {"type": "text", "value": "登录"},
        {"type": "css", "value": ".login-btn"},
        {"type": "css", "value": ".btn-primary"}
      ],
      "description": "登录按钮",
      "version": 1
    },
    "verify_code_input": {
      "selectors": [
        {"type": "css", "value": "input[name='captcha']"},
        {"type": "css", "value": "input[placeholder*='验证码']"},
        {"type": "xpath", "value": "//input[@placeholder='请输入验证码']"}
      ],
      "description": "验证码输入框",
      "version": 1
    },
    "verify_code_image": {
      "selectors": [
        {"type": "css", "value": ".captcha-img"},
        {"type": "css", "value": "img[alt*='验证码']"},
        {"type": "xpath", "value": "//img[@alt='验证码']"}
      ],
      "description": "验证码图片",
      "version": 1
    },
    "get_verify_code_button": {
      "selectors": [
        {"type": "text", "value": "获取验证码"},
        {"type": "css", "value": ".get-code-btn"},
        {"type": "xpath", "value": "//button[contains(text(),'获取验证码')]"}
      ],
      "description": "获取验证码按钮",
      "version": 1
    },
    "error_message": {
      "selectors": [
        {"type": "css", "value": ".error-message"},
        {"type": "css", "value": ".error-tip"},
        {"type": "xpath", "value": "//div[@class='error-message']"}
      ],
      "description": "错误提示信息",
      "version": 1
    }
  }
}