# MediaMTX browser-playback host for ICE candidates.
# Use the host/IP that browsers use to access MediaMTX.
MTX_WEBRTCADDITIONALHOSTS=127.0.0.1

# Logical stream names (used by browser-control in NDI mode).
P1_STREAM_NAME=p1-screen
P2_STREAM_NAME=p2-screen

# NDI source names as seen by local ffmpeg's libndi_newtek input.
NDI_SOURCE_P1=Player1 (Program)
NDI_SOURCE_P2=Player2 (Program)

# Optional discovery settings for local ffmpeg.
# NDI discovery server host:port (example: 192.168.1.50:5959).
NDI_DISCOVERY_SERVER=
# Optional comma-separated sender IPs for targeted scan
# (example: 192.168.1.101,192.168.1.102).
NDI_EXTRA_IPS=
